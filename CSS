.games{
padding:15px;
}

.game-grid{
display:grid;
grid-template-columns:1fr 1fr;
gap:15px;
}

.game-card{
background:#1c1c1c;
border-radius:18px;
overflow:hidden;
text-decoration:none;
box-shadow:0 0 10px rgba(0,0,0,0.5);
}

.game-card img{
width:100%;
height:140px;
object-fit:cover;
display:block;
}

.game-card p{
color:white;
text-align:center;
padding:12px;
font-size:18px;
font-weight:bold;
}
